{
  "allowedTools": [
    "Bash(npm test:*)",
    "Bash(curl:*)",
    "Bash(cd:*)",
    "Bash(npx:*)",
    "Edit",
    "Write",
    "Read",
    "Glob",
    "Grep"
  ],
  "hooks": {
    "postEdit": {
      "command": "npx eslint --fix {{file}}",
      "description": "Auto-lint JS files after editing"
    }
  }
}
