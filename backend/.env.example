PORT=5000
NODE_ENV=production
FRONTEND_URL=https://shouldigo.surf
BRIGHT_DATA_API_KEY=your_api_key_here

# Firebase Cloud Messaging (Android push notifications)
# Base64-encoded Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT=

# Optional split credentials by purpose (preferred in production)
FCM_SERVICE_ACCOUNT=
GA_SERVICE_ACCOUNT=
SEARCH_CONSOLE_SERVICE_ACCOUNT=

# Marketing / admin auth
ADMIN_SECRET=
MARKETING_ADMIN_EMAILS=
SCHEDULER_SERVICE_ACCOUNT_EMAIL=
GOOGLE_OIDC_AUDIENCE=https://api.shouldigo.surf

# GA4 reporting
GA_PROPERTY_ID=

# Daily report email
REPORT_EMAIL=
REPORT_FROM_EMAIL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Meta ads
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_CAMPAIGN_ID=
META_ADSET_ID=
META_AD_DAILY_BUDGET=500

# Cloud Run: leave false and trigger these routes with Cloud Scheduler instead
ENABLE_IN_PROCESS_MARKETING_SCHEDULERS=false
